{
  "name": "codetreeviewer",
  "version": "0.0.0",
  "description": "프로젝트 내부 파일/함수 관계를 관계도·트리로 시각화하는 데스크톱 앱",
  "main": "./out/main/index.js",
  "author": "BluewhaleYH",
  "license": "MIT",
  "private": true,
  "scripts": {
    "dev": "cross-env ELECTRON_DISABLE_SANDBOX=1 electron-vite dev",
    "start": "cross-env ELECTRON_DISABLE_SANDBOX=1 electron-vite preview",
    "build": "npm run typecheck && electron-vite build",
    "typecheck": "npm run typecheck:node && npm run typecheck:web",
    "typecheck:node": "tsc -p tsconfig.node.json",
    "typecheck:web": "tsc -p tsconfig.web.json",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:watch": "vitest",
    "screenshot": "cross-env CAPTURE_SCREENSHOT=1 ELECTRON_DISABLE_SANDBOX=1 electron-vite dev",
    "build:linux": "npm run build && electron-builder --linux AppImage deb",
    "build:win": "npm run build && electron-builder --win zip",
    "build:win:installer": "npm run build && electron-builder --win nsis"
  },
  "dependencies": {
    "tree-sitter-wasms": "^0.1.13",
    "web-tree-sitter": "^0.20.8"
  },
  "devDependencies": {
    "@eslint/js": "^9.13.0",
    "@types/node": "^22.7.0",
    "cross-env": "^7.0.3",
    "electron": "^33.0.0",
    "electron-builder": "^25.1.0",
    "electron-vite": "^2.3.0",
    "eslint": "^9.13.0",
    "prettier": "^3.3.0",
    "typescript": "^5.6.0",
    "typescript-eslint": "^8.10.0",
    "vite": "^5.4.0",
    "vitest": "^2.1.0"
  },
  "allowScripts": {
    "esbuild@0.21.5": true,
    "electron@33.4.11": true
  }
}
